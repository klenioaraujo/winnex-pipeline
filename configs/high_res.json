{
  "__meta__": "Madhava Pipeline — High Resolution Preset [64,128]",
  "version": "12.1.0",

  "model": {
    "name": "all-MiniLM-L6-v2",
    "dimension": 384,
    "device": "cpu",
    "normalize": true,
    "max_length": 256,
    "batch_size": 64
  },

  "dimensions": {
    "input_dim": 384,
    "stage_dims": [64, 128],
    "qjl_dim": 128
  },

  "search": {
    "adaptive_keep_base": 0.30,
    "adaptive_keep_min": 0.10,
    "adaptive_keep_max": 0.60,
    "adaptive_bounds_sensitivity": 0.10,
    "stage2_topk": 1000,
    "stage2_topk_max": 2000,
    "final_results": 10,
    "epsilon": 1e-5
  },

  "hybrid": {
    "enabled": true,
    "n_cells": 128,
    "n_probe": [5, 10, 15, 20, 30],
    "clustering": {
      "algorithm": "MiniBatchKMeans",
      "random_state": 42,
      "batch_size": 20000,
      "n_init": 3,
      "max_iter": 50
    }
  },

  "bounds": {
    "cauchy_schwarz_epsilon": 1e-5,
    "orthogonality_tolerance": 1e-5
  },

  "modulation": {
    "error_backprop": true,
    "alpha_smoothing": 0.3,
    "alpha_min": 0.01,
    "alpha_max": 0.99
  }
}
